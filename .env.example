# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App (required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (required for application emails) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Court Society <nominations@courtsociety.org>

# --- Sentry (recommended for production) ---
# Same DSN used in both. NEXT_PUBLIC_ exposes it to the browser bundle
# (this is safe — Sentry DSNs are public by design).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# For source map upload at build time (optional but recommended).
# Set these in Vercel only; do not commit.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Phase 2 (optional, leave empty for MVP) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
